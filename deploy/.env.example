# Copy to .env and fill in real secrets before any non-local deployment.
POSTGRES_PASSWORD=change-me-in-prod
MINIO_USER=fadstream
MINIO_PASSWORD=change-me-in-prod
JWT_SECRET=generate-a-long-random-string

# TURN relay (only needed for real internet / mobile, not local LAN testing)
TURN_PASSWORD=change-me-in-prod
TURN_PUBLIC_IP=127.0.0.1   # set to your server's PUBLIC IP when deploying
